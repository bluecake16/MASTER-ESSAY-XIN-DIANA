   "source": [
    "# Appendix\n",
    "# ═══════════════════════════════════════════════════════════════\n",
    "# PHASE C — branch 1 Type 3b Supplementary Check:\n",
    "# Horizon-wise 2D ES (continuous-value only)\n",
    "#\n",
    "# Purpose:\n",
    "#   Check whether a lower-dimensional ES, aligned with the\n",
    "#   contemporaneous cross-variable distortion in Type 3b,\n",
    "#   shows a clearer signal than the full-path ES.\n",
    "#\n",
    "# Definition:\n",
    "#   For each horizon t, compute a bivariate ES on the 2D ensemble\n",
    "#   {(price_t, temp_t)} against the realized point (real_p_t, real_t_t),\n",
    "#   then average across horizons.\n",
    "#\n",
    "# Scaling:\n",
    "#   Use the same frozen pooled benchmark scaling as Phase A / Phase B:\n",
    "#   MU_PRICE_ES, SD_PRICE_ES, MU_TEMP_ES, SD_TEMP_ES\n",
    "# ═══════════════════════════════════════════════════════════════\n",
    "\n",
    "# smaller prototype budget\n",
    "N_rep_es2d_check = 100\n",
    "\n",
    "# subsample horizons to reduce runtime\n",
    "h_idx = np.arange(0, n_horizons_c, 6)   # 720 -> 120 horizons\n",
    "\n",
    "def energy_score_2d_horizon_fast(ens_p, ens_t, real_p, real_t,\n",
    "                                 mu_p, sd_p, mu_t, sd_t):\n",
    "    zp = (ens_p - mu_p) / sd_p\n",
    "    zt = (ens_t - mu_t) / sd_t\n",
    "    zr_p = (real_p - mu_p) / sd_p\n",
    "    zr_t = (real_t - mu_t) / sd_t\n",
    "\n",
    "    X = np.column_stack([zp, zt])\n",
    "    y = np.array([zr_p, zr_t], dtype=float)\n",
    "\n",
    "    term1 = np.mean(np.linalg.norm(X - y[None, :], axis=1))\n",
    "    term2 = 0.5 * np.mean(np.linalg.norm(X[:, None, :] - X[None, :, :], axis=2))\n",
    "    return float(term1 - term2)\n",
    "\n",
    "def energy_score_2d_path_average_fast(sims_p, sims_t, real_p, real_t,\n",
    "                                      mu_p, sd_p, mu_t, sd_t, horizon_idx):\n",
    "    vals = []\n",
    "    for t in horizon_idx:\n",
    "        vals.append(\n",
    "            energy_score_2d_horizon_fast(\n",
    "                sims_p[t, :], sims_t[t, :],\n",
    "                real_p[t], real_t[t],\n",
    "                mu_p, sd_p, mu_t, sd_t\n",
    "            )\n",
    "        )\n",
    "    return float(np.mean(vals))\n",
    "\n",
    "records_t3b_es2d_fast = []\n",
    "rng_t3b_es2d_fast = np.random.default_rng(SEED_C + 352)\n",
    "\n",
    "for delta_rho in delta_rhos:\n",
    "    rho_F = rho + delta_rho\n",
    "    if not (-1 < rho_F < 1):\n",
    "        raise ValueError(f\"Invalid rho_F={rho_F:.3f}\")\n",
    "\n",
    "    cov_F = np.array([\n",
    "        [sigma_price**2,                    rho_F * sigma_price * sigma_temp],\n",
    "        [rho_F * sigma_price * sigma_temp,  sigma_temp**2]\n",
    "    ])\n",
    "    L_F = np.linalg.cholesky(cov_F)\n",
    "\n",
    "    for rep in range(N_rep_es2d_check):\n",
    "        Z_r = rng_t3b_es2d_fast.standard_normal((n_horizons_c, 2))\n",
    "        eps_r = Z_r @ L.T\n",
    "        real_p = mean_price_c + eps_r[:, 0]\n",
    "        real_t = mean_temp_c  + eps_r[:, 1]\n",
    "\n",
    "        Z_s = rng_t3b_es2d_fast.standard_normal((n_horizons_c, n_paths_c, 2))\n",
    "        eps_s = Z_s @ L_F.T\n",
    "        sims_p = mean_price_c[:, None] + eps_s[:, :, 0]\n",
    "        sims_t = mean_temp_c[:, None]  + eps_s[:, :, 1]\n",
    "\n",
    "        es_2d_avg = energy_score_2d_path_average_fast(\n",
    "            sims_p, sims_t, real_p, real_t,\n",
    "            MU_PRICE_ES, SD_PRICE_ES, MU_TEMP_ES, SD_TEMP_ES,\n",
    "            h_idx\n",
    "        )\n",
    "\n",
    "        records_t3b_es2d_fast.append({\n",
    "            'delta_rho': delta_rho,\n",
    "            'rho_F': rho_F,\n",
    "            'rep': rep,\n",
    "            'es_2d_avg': es_2d_avg\n",
    "        })\n",
    "\n",
    "    print(f\"Δρ={delta_rho:>6.2f}  (ρ_F={rho_F:.2f})  done — {N_rep_es2d_check} reps\")\n",
    "\n",
    "df_t3b_es2d_fast = pd.DataFrame(records_t3b_es2d_fast)\n",
    "\n",
    "summary_t3b_es2d_fast = (\n",
    "    df_t3b_es2d_fast\n",
    "    .groupby('delta_rho')\n",
    "    .agg(\n",
    "        rho_F=('rho_F', 'first'),\n",
    "        es_2d_mean=('es_2d_avg', 'mean'),\n",
    "        es_2d_median=('es_2d_avg', 'median'),\n",
    "        es_2d_std=('es_2d_avg', 'std')\n",
    "    )\n",
    "    .sort_index()\n",
    ")\n",
    "\n",
    "print(summary_t3b_es2d_fast.round(4).to_string())"
   ]
  },

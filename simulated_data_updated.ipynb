    "# ═══════════════════════════════════════════════════════════════\n# PHASE C — Branch 1, Type 3a: Temporal Dependence Distortion\n#\n# Misspecification: forecast paths are oversmoothed via moving\n# average (MA) with half-window K. Larger K = stronger smoothing\n# = more severe temporal dependence distortion.\n#\n# Truth:    always drawn from correct benchmark DGP (no smoothing)\n# Forecast: MA-smoothed ensemble, then per-horizon recenter/rescale\n#           anchored back to benchmark to isolate dependence distortion\n#           from Type 1 / Type 2 contamination.\n#\n# Primary diagnostic: VS (lag-restricted variogram score)\n# Secondary:          LB, ES\n# Expected weak:      KS, AD, Coverage\n# ═══════════════════════════════════════════════════════════════\nfrom scipy.ndimage import uniform_filter1d\n\n# ── Helper function: anchored recenter + rescale ──────────────\n# Rescales distorted ensemble back to benchmark per-horizon\n# mean and std, isolating dependence distortion from Type 1/2.\ndef anchor_recenter_rescale(sims_dist, sims_bench):\n    bench_mean = sims_bench.mean(axis=1, keepdims=True)\n    bench_std  = sims_bench.std(axis=1,  keepdims=True)\n    dist_mean  = sims_dist.mean(axis=1,  keepdims=True)\n    dist_std   = sims_dist.std(axis=1,   keepdims=True)\n    dist_std   = np.where(dist_std < 1e-8, 1.0, dist_std)\n    return ((sims_dist - dist_mean) / dist_std) * bench_std + bench_mean\n\nrecords_t3a = []\nrng_t3a = np.random.default_rng(SEED_C + 300)\n\nfor K in Ks:\n    window = 2 * K + 1\n\n    for rep in range(N_rep_c):\n\n        # ── Truth: always correct DGP, never distorted ────────\n        Z_r    = rng_t3a.standard_normal((n_horizons_c, 2))\n        eps_r  = Z_r @ L.T\n        real_p = mean_price_c + eps_r[:, 0]\n        real_t = mean_temp_c  + eps_r[:, 1]\n\n        # ── Benchmark forecast ensemble ───────────────────────\n        Z_s    = rng_t3a.standard_normal((n_horizons_c, n_paths_c, 2))\n        eps_s  = Z_s @ L.T\n        sims_p 
    "# ═══════════════════════════════════════════════════════════════\n",
    "# PHASE C — Branch 2, Scenario B\n",
    "# Step 1–4: path decomposition, distortion, and horizon-wise re-anchoring\n",
    "# ═══════════════════════════════════════════════════════════════\n",
    "\n",
    "# -------------------------------------------------------------\n",
    "# Helper 1: rolling mean with edge padding\n",
    "# Input shape: (H, N)  where H = horizons, N = paths\n",
    "# Smoothing is applied along horizon axis (axis=0)\n",
    "# -------------------------------------------------------------\n",
    "def rolling_mean_paths(X, K=12, pad_mode=\"edge\"):\n",
    "    \"\"\"\n",
    "    Rolling mean smoothing for ensemble paths.\n",
    "\n",
    "    Parameters\n",
    "    ----------\n",
    "    X : np.ndarray, shape (H, N)\n",
    "        Forecast ensemble paths.\n",
    "    K : int\n",
    "        Half-window size. Full window = 2K+1.\n",
    "        Consistent with Type 3a definition.\n",
    "    pad_mode : str\n",
    "        Padding mode for np.pad, e.g. 'edge' or 'reflect'.\n",
    "\n",
    "    Returns\n",
    "    -------\n",
    "\n",
    "    S : np.ndarray, shape (H, N)\n",
    "        Smoothed backbone.\n",
    "    \"\"\"\n",
    "    window = 2 * K + 1\n",
    "    X_pad  = np.pad(X, ((K, K), (0, 0)), mode=pad_mode)\n",
    "    S      = np.empty_like(X, dtype=float)\n",
    "    for t in range(X.shape[0]):\n",
    "        S[t, :] = X_pad[t:t + window, :].mean(axis=0)\n",
    "    return S\n",
    "\n",
    "\n",
    "# -------------------------------------------------------------\n",
    "# Helper 2: horizon-wise recenter and rescale\n",
    "# Re-anchor distorted ensemble to benchmark horizon-wise mean/sd\n",
    "# -------------------------------------------------------------\n",
    "def horizon_recenter_rescale(X_raw, X_bench, eps=1e-12):\n",
    "    \"\"\"\n",
    "    Recenter and rescale distorted ensemble horizon by horizon.\n",
    "\n",
    "    Parameters\n",
    "    ----------\n",
    "    X_raw : np.ndarray, shape (H, N)\n",
    "        Raw distorted ensemble.\n",
    "    X_bench : np.ndarray, shape (H, N)\n",
    "        Benchmark ensemble used as horizon-wise anchor.\n",
    "    eps : float\n",
    "        Small constant to avoid division by zero.\n",
    "\n",
    "    Returns\n",
    "    -------\n",
    "    X_dist : np.ndarray, shape (H, N)\n",
    "        Re-anchored distorted ensemble.\n",
    "    \"\"\"\n",
    "    mu_bench = X_bench.mean(axis=1, keepdims=True)                 # (H, 1)\n",
    "    sd_bench = X_bench.std(axis=1, ddof=1, keepdims=True)         # (H, 1)\n",
    "\n",
    "    mu_raw = X_raw.mean(axis=1, keepdims=True)                    # (H, 1)\n",
    "    sd_raw = X_raw.std(axis=1, ddof=1, keepdims=True)             # (H, 1)\n",
    "\n",
    "    X_dist = mu_bench + (sd_bench / np.maximum(sd_raw, eps)) * (X_raw - mu_raw)\n",
    "    return X_dist\n",
    "\n",
    "\n",
    "# -------------------------------------------------------------\n",
    "# Helper 3: full Scenario B transform\n",
    "# -------------------------------------------------------------\n",
    "def scenarioB_distort(X_base, K=12, eta=1.0, pad_mode=\"edge\"):\n",
    "    \"\"\"\n",
    "    Construct Scenario B distorted ensemble for one variable.\n",
    "\n",
    "    Parameters\n",
    "    ----------\n",
    "    X_base : np.ndarray, shape (H, N)\n",
    "        Benchmark forecast ensemble.\n",
    "    K : int\n",
    "    Half-window size. Full window = 2K+1.\n",
    "    Consistent with Type 3a definition.\n",
    "    eta : float\n",
    "        Distortion factor:\n",
    "            eta < 1   -> smoother paths\n",
    "            eta = 1   -> baseline\n",
    "            eta > 1   -> rougher paths\n",
    "    pad_mode : str\n",
    "        Padding mode for smoothing.\n",
    "\n",
    "    Returns\n",
    "    -------\n",
    "    out : dict\n",
    "        Contains:\n",
    "        - 'S'      : smoothed backbone\n",
    "        - 'R'      : high-frequency residual\n",
    "        - 'X_raw'  : raw distorted ensemble\n",
    "        - 'X_dist' : final re-anchored distorted ensemble\n",
    "    \"\"\"\n",
    "    S = rolling_mean_paths(X_base, K=K, pad_mode=pad_mode)\n",
    "    R = X_base - S\n",
    "    X_raw = S + eta * R\n",
    "    X_dist = horizon_recenter_rescale(X_raw, X_base)\n",
    "\n",
    "    return {\n",
    "        \"S\": S,\n",
    "        \"R\": R,\n",
    "        \"X_raw\": X_raw,\n",
    "        \"X_dist\": X_dist\n",
    "    }"
   ]

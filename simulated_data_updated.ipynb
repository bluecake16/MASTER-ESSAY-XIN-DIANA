    "# ═══════════════════════════════════════════════════════════════\n",
    "# PHASE C — Branch 2, Scenario B: Path Dynamics Distortion\n",
    "#\n",
    "# Distortion family: X̃ = S + η·R, then horizon_recenter_rescale\n",
    "#   S = rolling mean (K=12, half-window; full window=25)\n",
    "#   R = X - S (residual component)\n",
    "#   η=0.25 → over-smooth; η=1.0 → baseline (null); η=2.0 → over-rough\n",
    "#\n",
    "# Primary diagnostic:   per-variable lag-restricted VS\n",
    "# Supporting:           ES, PIT-based LB (Gaussianized PIT)\n",
    "# Expected weak:        KS, AD, Coverage (marginals preserved by design)\n",
    "# ═══════════════════════════════════════════════════════════════\n",
    "\n",
    "etas       = [0.25, 1.0, 2.0]\n",
    "K_scen_b   = 12   # half-window; full window = 2*12+1 = 25\n",
    "\n",
    "records_scenb = []\n",
    "rng_scenb     = np.random.default_rng(SEED_C + 400)\n",
    "\n",
    "for eta in etas:\n",
    "    for rep in range(N_rep_c):\n",
    "\n",
    "        # ── Truth: benchmark DGP ──────────────────────────────\n",
    "        Z_r    = rng_scenb.standard_normal((n_horizons_c, 2))\n",
    "        eps_r  = Z_r @ L.T\n",
    "        real_p = mean_price_c + eps_r[:, 0]\n",
    "        real_t = mean_temp_c  + eps_r[:, 1]\n",
    "\n",
    "        # ── Base forecast: correct DGP ────────────────────────\n",
    "        Z_s    = rng_scenb.standard_normal((n_horizons_c, n_paths_c, 2))\n",
    "        eps_s  = Z_s @ L.T\n",
    "        base_p = mean_price_c[:, None] + eps_s[:, :, 0]\n",
    "        base_t = mean_temp_c[:, None]  + eps_s[:, :, 1]\n",
    "\n",
    "        # ── Distort forecast paths ────────────────────────────\n",
    "        sims_p = scenarioB_distort(base_p, K=K_scen_b, eta=eta)[\"X_dist\"]\n",
    "        sims_t = scenarioB_distort(base_t, K=K_scen_b, eta=eta)[\"X_dist\"]\n",
    "\n",
    "        # ── Run diagnostics ───────────────────────────────────\n",
    "        rng_diag = np.random.default_rng(rng_scenb.integers(1_000_000))\n",
    "        diag     = run_diagnostics_c(sims_p, sims_t, real_p, real_t, rng_diag)\n",
    "\n",
    "        records_scenb.append({\n",
    "            \"eta\":          eta,\n",
    "            \"rep\":          rep,\n",
    "            # Primary\n",
    "            \"vs_p_rej\":     diag[\"vs_p_rej\"],\n",
    "            \"vs_t_rej\":     diag[\"vs_t_rej\"],\n",
    "            # Supporting\n",
    "            \"es_rej\":       diag[\"es_rej\"],\n",
    "            \"lb_rej_p_24\":  diag[\"lb_rej_p_24\"],\n",
    "            \"lb_rej_t_24\":  diag[\"lb_rej_t_24\"],\n",
    "            \"lb_rej_p_168\": diag[\"lb_rej_p_168\"],\n",
    "            \"lb_rej_t_168\": diag[\"lb_rej_t_168\"],\n",
    "            # Appendix\n",
    "            \"ks_rej_p\":     diag[\"ks_rej_p\"],\n",
    "            \"ks_rej_t\":     diag[\"ks_rej_t\"],\n",
    "            \"ad_rej_p\":     diag[\"ad_rej_p\"],\n",
    "            \"ad_rej_t\":     diag[\"ad_rej_t\"],\n",
    "            \"cov90_rej\":    diag[\"cov90_rej\"],\n",
    "        })\n",
    "\n",
    "# ── Summary tables ────────────────────────────────────────────\n",
    "df_scenb = pd.DataFrame(records_scenb)\n",
    "\n",
    "# Main table: primary + supporting diagnostics\n",
    "main_cols = [\"vs_p_rej\", \"vs_t_rej\", \"es_rej\",\n",
    "             \"lb_rej_p_24\", \"lb_rej_t_24\", \"lb_rej_p_168\", \"lb_rej_t_168\"]\n",
    "\n",
    "summary_main = (\n",
    "    df_scenb.groupby(\"eta\")[main_cols]\n",
    "    .mean().round(3)\n",
    ")\n",
    "\n",
    "# Appendix table: marginal diagnostics (expected weak)\n",
    "app_cols = [\"ks_rej_p\", \"ks_rej_t\", \"ad_rej_p\", \"ad_rej_t\", \"cov90_rej\"]\n",
    "\n",
    "summary_app = (\n",
    "    df_scenb.groupby(\"eta\")[app_cols]\n",
    "    .mean().round(3)\n",
    ")\n",
    "\n",
    "print(\"Scenario B — Main table (Primary + Supporting diagnostics)\")\n",
    "print(\"η=1.0 is the null; expected: vs_p/vs_t rise with |η−1|\")\n",
    "print(summary_main.to_string())\n",
    "\n",
    "print(\"\\nScenario B — Appendix table (marginal diagnostics, expected ~0.05)\")\n",
    "print(summary_app.to_string())\n"

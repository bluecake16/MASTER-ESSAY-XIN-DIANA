    "    n_viol = int(np.sum((real_p < q_lo) | (real_p > q_hi)))\n",
    "    cov90_rej = int(binomtest(n_viol, H, 0.10).pvalue < alpha_c)\n",
    "\n",
    "    # ── Collect results ─────────────────────────────────────────\n",
    "    rec = {\n",
    "        'ks_rej_p':  ks_rej_p,\n",
    "        'ks_rej_t':  ks_rej_t,\n",
    "        'ad_rej_p':  ad_rej_p,\n",
    "        'ad_rej_t':  ad_rej_t,\n",
    "        'es_rej':    es_rej,\n",
    "        'es_val':    float(es_val),\n",
    "        'vs_rej':    vs_rej,\n",
    "        'vs_val':    float(vs_val),\n",

   "source": [
    "# ═══════════════════════════════════════════════════════════════\n",
    "# PHASE C — Branch 2, Scenario A: Price Spike / Tail Stress\n",
    "#\n",
    "# = Severe Type 4 case (ν = 3, scale-corrected Student-t noise)\n",
    "# Truth: heavy-tailed price shocks (simulated realized path)\n",
    "# Forecast: standard normal ensemble (unaware of heavy tails)\n",
    "#\n",
    "# Primary diagnostics: AD · tail exceedance · ES\n",
    "# Expected weak:       KS (less sensitive to tails), VS, Coverage-90\n",
    "# ═══════════════════════════════════════════════════════════════\n",
    "\n",
    "from scipy.stats import anderson, norm\n",
    "\n",
    "N_rep_scA   = 500\n",
    "nu_scA      = 3       # severe: df=3 → very heavy tails\n",
    "alpha_scA   = 0.05\n",
    "\n",
    "rng_scA = np.random.default_rng(SEED_C + 600)\n",
    "\n",
    "records_scenA = []\n",
    "\n",
    "for rep in range(N_rep_scA):\n",
    "\n",
    "    # ── Truth: heavy-tailed realized path (Student-t shocks) ──\n",
    "    # Scale-corrected: multiply by sqrt((ν-2)/ν) so variance matches σ²\n",
    "    scale_corr = np.sqrt((nu_scA - 2) / nu_scA)\n",
    "\n",
    "    Z_r_t = rng_scA.standard_t(df=nu_scA, size=(n_horizons_c, 2))\n",
    "    eps_r  = (Z_r_t * scale_corr) @ L.T\n",
    "    real_p = mean_price_c + eps_r[:, 0]\n",
    "    real_t = mean_temp_c  + eps_r[:, 1]\n",
    "\n",
    "    # ── Forecast: normal ensemble (misspecified — unaware of heavy tails) ──\n",
    "    Z_s   = rng_scA.standard_normal((n_horizons_c, n_paths_c, 2))\n",
    "    eps_s = Z_s @ L.T\n",
    "    sims_p = mean_price_c[:, None] + eps_s[:, :, 0]\n",
    "    sims_t = mean_temp_c[:, None]  + eps_s[:, :, 1]\n",
    "\n",
    "    # ── PIT ──────────────────────────────────────────────────\n",
    "    def _pit_scA(sims, realized, rng):\n",
    "        ss    = np.sort(sims, axis=1)\n",
    "        H, N  = sims.shape\n",
    "        ranks = np.array([np.searchsorted(ss[i], realized[i], side='right')\n",
    "                          for i in range(H)], dtype=float)\n",
    "        u = rng.uniform(size=H)\n",
    "        return np.clip((ranks + u) / (N + 1.0), 1e-6, 1 - 1e-6)\n",
    "\n",
    "    pit_p = _pit_scA(sims_p, real_p, rng_scA)\n",
    "    pit_t = _pit_scA(sims_t, real_t, rng_scA)\n",
    "    z_p   = norm.ppf(pit_p)\n",
    "    z_t   = norm.ppf(pit_t)\n",
    "\n",
    "    # ── AD test (primary) ────────────────────────────────────\n",
    "    ad_p = anderson(z_p, dist='norm')\n",
    "    ad_t = anderson(z_t, dist='norm')\n",
    "    idx5_p = int(np.where(np.isclose(ad_p.significance_level, 5.0))[0][0])\n",
    "    idx5_t = int(np.where(np.isclose(ad_t.significance_level, 5.0))[0][0])\n",
    "    ad_rej_p = int(ad_p.statistic > ad_p.critical_values[idx5_p])\n",
    "    ad_rej_t = int(ad_t.statistic > ad_t.critical_values[idx5_t])\n",
    "\n",
    "    # ── KS test (secondary / expected weak) ──────────────────\n",
    "    ks_rej_p = int(stats.kstest(pit_p, 'uniform').pvalue < alpha_scA)\n",
    "    ks_rej_t = int(stats.kstest(pit_t, 'uniform').pvalue < alpha_scA)\n",
    "\n",
    "    # ── Tail exceedance (primary) ─────────────────────────────\n",
    "    # Fraction of realized values falling outside forecast q_0.01 / q_0.99\n",
    "    q_lo_p = np.quantile(sims_p, q_tail_lo, axis=1)\n",
    "    q_hi_p = np.quantile(sims_p, q_tail_hi, axis=1)\n",
    "    q_lo_t = np.quantile(sims_t, q_tail_lo, axis=1)\n",
    "    q_hi_t = np.quantile(sims_t, q_tail_hi, axis=1)\n",
    "\n",
    "    exc_lo_p = float((real_p < q_lo_p).mean())\n",
    "    exc_hi_p = float((real_p > q_hi_p).mean())\n",
    "    exc_lo_t = float((real_t < q_lo_t).mean())\n",
    "    exc_hi_t = float((real_t > q_hi_t).mean())\n",
    "\n",
    "    # Combined tail exceedance rate (nominal = 0.02 under correct spec)\n",
    "    tail_exc_p = exc_lo_p + exc_hi_p\n",
    "    tail_exc_t = exc_lo_t + exc_hi_t\n",
    "\n",
    "    # ── Energy Score (primary) ────────────────────────────────\n",
    "    es_val, _, _ = energy_score(\n",
    "        sims_p, sims_t, real_p, real_t,\n",
    "        MU_PRICE_ES, SD_PRICE_ES, MU_TEMP_ES, SD_TEMP_ES,\n",
    "        M=200, R=3, seed=int(rng_scA.integers(1_000_000))\n",
    "    )\n",
    "\n",
    "    records_scenA.append({\n",
    "        'rep':         rep,\n",
    "        'ad_rej_p':    ad_rej_p,\n",
    "        'ad_rej_t':    ad_rej_t,\n",
    "        'ks_rej_p':    ks_rej_p,\n",
    "        'ks_rej_t':    ks_rej_t,\n",
    "        'exc_lo_p':    exc_lo_p,\n",
    "        'exc_hi_p':    exc_hi_p,\n",
    "        'exc_lo_t':    exc_lo_t,\n",
    "        'exc_hi_t':    exc_hi_t,\n",
    "        'tail_exc_p':  tail_exc_p,\n",
    "        'tail_exc_t':  tail_exc_t,\n",
    "        'es':          es_val,\n",
    "    })\n",
    "\n",
    "df_scA = pd.DataFrame(records_scenA)\n",
    "\n",
    "# ── Summary ───────────────────────────────────────────────────\n",
    "print(\"=\" * 60)\n",
    "print(f\"Scenario A: Price Spike / Tail Stress  (ν={nu_scA}, N_rep={N_rep_scA})\")\n",
    "print(\"=\" * 60)\n",
    "print(f\"\\nPrimary diagnostics (expected HIGH power):\")\n",
    "print(f\"  AD rej rate  — price : {df_scA['ad_rej_p'].mean():.3f}\")\n",
    "print(f\"  AD rej rate  — temp  : {df_scA['ad_rej_t'].mean():.3f}\")\n",
    "print(f\"  Mean tail_exc — price: {df_scA['tail_exc_p'].mean():.4f}  (nominal=0.02)\")\n",
    "print(f\"  Mean tail_exc — temp : {df_scA['tail_exc_t'].mean():.4f}  (nominal=0.02)\")\n",
    "print(f\"  Mean ES              : {df_scA['es'].mean():.4f}\")\n",
    "print(f\"  ES vs null threshold ({es_threshold:.4f}): \"\n",
    "      f\"{'above' if df_scA['es'].mean() > es_threshold else 'below'}\")\n",
    "\n",
    "print(f\"\\nSecondary diagnostic (expected weaker):\")\n",
    "print(f\"  KS rej rate  — price : {df_scA['ks_rej_p'].mean():.3f}\")\n",
    "print(f\"  KS rej rate  — temp  : {df_scA['ks_rej_t'].mean():.3f}\")\n",
    "\n",
    "print(f\"\\nTail breakdown (price):\")\n",
    "print(f\"  exc_lo (< q_0.01): {df_scA['exc_lo_p'].mean():.4f}\")\n",
    "print(f\"  exc_hi (> q_0.99): {df_scA['exc_hi_p'].mean():.4f}\")"
   ]

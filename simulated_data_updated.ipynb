    "# ═══════════════════════════════════════════════════════════════\n",
    "# PHASE C — Branch 1:Type 3a Prototype: ACF Signal Verification\n",
    "\n",
    "# Purpose: Before running the full MC loop, verify on a single\n",
    "# (truth, forecast) pair that:\n",
    "#   1. MA smoothing changes the temporal dependence structure\n",
    "#   2. Per-horizon recenter/rescale does NOT eliminate the signal\n",
    "#   3. Marginal distribution (mean, std) is preserved after rescaling\n",
    "# ═══════════════════════════════════════════════════════════════\n",
    "from statsmodels.tsa.stattools import acf\n",
    "\n",
    "# ── Step 1: Generate one benchmark forecast ensemble ─────────\n",
    "rng_proto = np.random.default_rng(SEED_C)\n",
    "\n",
    "Z_r   = rng_proto.standard_normal((n_horizons_c, 2))\n",
    "eps_r = Z_r @ L.T\n",
    "real_p_proto = mean_price_c + eps_r[:, 0]   # realized truth, shape (H,)\n",
    "\n",
    "Z_s   = rng_proto.standard_normal((n_horizons_c, n_paths_c, 2))\n",
    "eps_s = Z_s @ L.T\n",
    "sims_p_bench = mean_price_c[:, None] + eps_s[:, :, 0]  # benchmark, shape (H, N)\n",
    "\n",
    "# ── Step 2: Apply MA smoothing with K=12 (window=25) ─────────\n",
    "K_proto = 12\n",
    "kernel  = np.ones(2 * K_proto + 1) / (2 * K_proto + 1)\n",
    "\n",
    "H, N = sims_p_bench.shape\n",
    "sims_p_smooth_raw = np.empty_like(sims_p_bench)\n",
    "\n",
    "for i in range(N):\n",
    "    x_padded = np.pad(sims_p_bench[:, i], K_proto, mode='edge')  # replicate padding\n",
    "    sims_p_smooth_raw[:, i] = np.convolve(x_padded, kernel, mode='valid')\n",
    "\n",
    "# ── Step 3: Anchored recenter + rescale back to benchmark ─────\n",
    "bench_mean_p = sims_p_bench.mean(axis=1)   # (H,)\n",
    "bench_std_p  = sims_p_bench.std(axis=1)    # (H,)\n",
    "\n",
    "dist_mean_p = sims_p_smooth_raw.mean(axis=1, keepdims=True)\n",
    "dist_std_p  = sims_p_smooth_raw.std(axis=1, keepdims=True)\n",
    "dist_std_p  = np.where(dist_std_p < 1e-8, 1.0, dist_std_p)\n",
    "\n",
    "sims_p_smooth = (\n",
    "    (sims_p_smooth_raw - dist_mean_p) / dist_std_p\n",
    ") * bench_std_p[:, None] + bench_mean_p[:, None]\n",
    "\n",
    "# ── Step 4: Verify marginal preservation ─────────────────────\n",
    "mean_diff = np.abs(sims_p_smooth.mean(axis=1) - bench_mean_p).max()\n",
    "std_diff  = np.abs(sims_p_smooth.std(axis=1)  - bench_std_p).max()\n",
    "\n",
    "print(\"Marginal preservation check (should be ≈ 0):\")\n",
    "print(f\"  max |mean_smooth - mean_bench| = {mean_diff:.2e}\")\n",
    "print(f\"  max |std_smooth  - std_bench|  = {std_diff:.2e}\")\n",
    "\n",
    "# ── Step 5: Pick one representative path and compute ACF ─────\n",
    "path_idx = 0\n",
    "\n",
    "# Use benchmark empirical horizon-wise mean for consistent centering\n",
    "innov_bench      = sims_p_bench[:, path_idx]      - bench_mean_p\n",
    "innov_smooth_raw = sims_p_smooth_raw[:, path_idx] - bench_mean_p\n",
    "innov_smooth     = sims_p_smooth[:, path_idx]     - bench_mean_p\n",
    "\n",
    "# ── Step 6: Plot ACF comparison ──────────────────────────────\n",
    "fig, axes = plt.subplots(1, 3, figsize=(18, 4))\n",
    "fig.suptitle(\n",
    "    f\"Type 3a ACF Signal Verification — Price (K={K_proto}, window={2*K_proto+1})\",\n",
    "    fontsize=12\n",
    ")\n",
    "\n",
    "plot_acf(innov_bench, lags=200, alpha=0.05, zero=False, ax=axes[0])\n",
    "axes[0].set_title(\"Benchmark\\nExpected: near-zero ACF\")\n",
    "axes[0].set_xlabel(\"Lag (hours)\")\n",
    "axes[0].set_ylabel(\"Autocorrelation\")\n",
    "\n",
    "plot_acf(innov_smooth_raw, lags=200, alpha=0.05, zero=False, ax=axes[1])\n",
    "axes[1].set_title(\"Smoothed before rescale\\nExpected: persistent ACF\")\n",
    "axes[1].set_xlabel(\"Lag (hours)\")\n",
    "axes[1].set_ylabel(\"Autocorrelation\")\n",
    "\n",
    "plot_acf(innov_smooth, lags=200, alpha=0.05, zero=False, ax=axes[2])\n",
    "axes[2].set_title(\"Smoothed after anchored rescale\\nSignal should persist\")\n",
    "axes[2].set_xlabel(\"Lag (hours)\")\n",
    "axes[2].set_ylabel(\"Autocorrelation\")\n",
    "\n",
    "for ax in axes:\n",
    "    for lag_mark in [1, 2, 6, 12, 24, 48, 168]:\n",
    "        ax.axvline(lag_mark, color='red', alpha=0.3, linestyle='--', linewidth=0.8)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# ── Step 7: Numeric ACF values at key lags ───────────────────\n",
    "acf_bench      = acf(innov_bench,      nlags=168, fft=True)\n",
    "acf_smooth_raw = acf(innov_smooth_raw, nlags=168, fft=True)\n",
    "acf_smooth     = acf(innov_smooth,     nlags=168, fft=True)\n",
    "\n",
    "print(f\"\\nACF at key lags (K={K_proto}, replicate padding):\")\n",
    "print(f\"{'Lag':<8}{'Benchmark':>12}{'Raw smooth':>12}{'Rescaled':>12}\")\n",
    "print(\"-\" * 44)\n",
    "\n",
    "for lag in [1, 2, 6, 12, 24, 48, 168]:\n",
    "    print(f\"{lag:<8}{acf_bench[lag]:>12.4f}{acf_smooth_raw[lag]:>12.4f}{acf_smooth[lag]:>12.4f}\")\n"

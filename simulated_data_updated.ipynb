    "    )\n",
    "    es_rej = int(es_val > es_threshold)  # threshold from Phase B null study\n",
    "\n",
    "    # ── Variogram Score ─────────────────────────────────────────\n",
    "    # Uses the same lag set and normalized weights as Phase B.\n",
    "    # If lag 720 is present in lags_main and H=720, the scoring function\n",
    "    # should silently skip it, consistent with Phase B.\n",
    "    with warnings.catch_warnings():\n",
    "        warnings.simplefilter(\"ignore\")\n",
    "        vs_p, _ = lag_variogram_score(sims_p, real_p, lags_main, w_norm, beta=0.5)\n",
    "        vs_t, _ = lag_variogram_score(sims_t, real_t, lags_main, w_norm, beta=0.5)\n",
    "\n",
    "    vs_val = 0.5 * (vs_p + vs_t)\n",
    "    vs_rej   = int(vs_val > vs_threshold)     # joint threshold (Phase B p95 of vs_total)\n",

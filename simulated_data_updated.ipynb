    "# ═══════════════════════════════════════════════════════════════\n",
    "# PHASE C — Master Diagnostic Function \n",
    "# ═══════════════════════════════════════════════════════════════\n",
    "\n",
    "from scipy.stats import norm, anderson, binomtest\n",
    "lags_lb_c = [24, 168]   # LB lags (lag 720 excluded because lag must be < H)\n",
    "\n",
    "def run_diagnostics_c(sims_p, sims_t, real_p, real_t, rng_diag):\n",
    "    \"\"\"\n",
    "    Run all Phase C diagnostics on one (truth, forecast) pair.\n",
    "\n",
    "    Parameters\n",
    "    ----------\n",
    "    sims_p : np.ndarray\n",
    "        Simulated price paths, shape (H, N).\n",
    "    sims_t : np.ndarray\n",
    "        Simulated temperature paths, shape (H, N).\n",
    "    real_p : np.ndarray\n",
    "        Realized price path, shape (H,).\n",
    "    real_t : np.ndarray\n",
    "        Realized temperature path, shape (H,).\n",
    "    rng_diag : np.random.Generator\n",
    "        RNG used for randomized PIT and ES Monte Carlo subsampling.\n",
    "\n",
    "    Returns\n",
    "    -------\n",
    "    rec : dict\n",
    "        Dictionary containing rejection flags (1=reject, 0=not reject)\n",
    "        and score values.\n",
    "    \"\"\"\n",
    "\n",
    "    # ── Input checks ────────────────────────────────────────────\n",
    "    sims_p = np.asarray(sims_p, dtype=float)\n",
    "    sims_t = np.asarray(sims_t, dtype=float)\n",
    "    real_p = np.asarray(real_p, dtype=float)\n",
    "    real_t = np.asarray(real_t, dtype=float)\n",
    "\n",
    "    if sims_p.ndim != 2 or sims_t.ndim != 2:\n",
    "        raise ValueError(\"sims_p and sims_t must both be 2D arrays with shape (H, N).\")\n",
    "\n",
    "    if real_p.ndim != 1 or real_t.ndim != 1:\n",
    "        raise ValueError(\"real_p and real_t must both be 1D arrays with shape (H,).\")\n",
    "\n",
    "    if sims_p.shape != sims_t.shape:\n",
    "        raise ValueError(f\"sims_p.shape {sims_p.shape} != sims_t.shape {sims_t.shape}\")\n",
    "\n",
    "    H, N = sims_p.shape\n",
    "\n",
    "    if real_p.shape[0] != H or real_t.shape[0] != H:\n",
    "        raise ValueError(\n",
    "            f\"realized paths must have length H={H}, \"\n",
    "            f\"got len(real_p)={len(real_p)}, len(real_t)={len(real_t)}\"\n",
    "        )\n",
    "\n",
    "    # ── Randomized PIT ──────────────────────────────────────────\n",
    "    def _pit(sims, realized):\n",
    "        \"\"\"\n",
    "        Randomized PIT for ensemble forecasts.\n",
    "        sims: shape (H, N), realized: shape (H,)\n",
    "        \"\"\"\n",
    "        ss = np.sort(sims, axis=1)\n",
    "        ranks = np.array(\n",
    "            [np.searchsorted(ss[i], realized[i], side='right') for i in range(H)],\n",
    "            dtype=float\n",
    "        )\n",
    "        u = rng_diag.uniform(size=H)\n",
    "        pit = (ranks + u) / (N + 1.0)\n",
    "        return np.clip(pit, 1e-6, 1 - 1e-6)\n",
    "\n",
    "    pit_p = _pit(sims_p, real_p)\n",
    "    pit_t = _pit(sims_t, real_t)\n",
    "\n",
    "    # Gaussianized PIT for AD / Ljung–Box\n",
    "    z_p = norm.ppf(pit_p)\n",
    "    z_t = norm.ppf(pit_t)\n",
    "\n",
    "    # ── KS test on PIT uniformity ───────────────────────────────\n",
    "    ks_rej_p = int(stats.kstest(pit_p, 'uniform').pvalue < alpha_c)\n",
    "    ks_rej_t = int(stats.kstest(pit_t, 'uniform').pvalue < alpha_c)\n",
    "\n",
    "    # ── AD test on Gaussianized PIT ─────────────────────────────\n",
    "    # Explicitly use the 5% critical value rather than hard-coding index [2]\n",

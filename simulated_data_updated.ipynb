    "    ad_t = anderson(z_t, dist='norm')\n",
    "\n",
    "    idx_5_p = np.where(np.isclose(ad_p.significance_level, 5.0))[0]\n",
    "    idx_5_t = np.where(np.isclose(ad_t.significance_level, 5.0))[0]\n",
    "\n",
    "    if len(idx_5_p) == 0 or len(idx_5_t) == 0:\n",
    "        raise ValueError(\"Could not find 5% significance level in Anderson-Darling output.\")\n",
    "\n",
    "    ad_cv_5_p = ad_p.critical_values[idx_5_p[0]]\n",
    "    ad_cv_5_t = ad_t.critical_values[idx_5_t[0]]\n",
    "\n",
    "    ad_rej_p = int(ad_p.statistic > ad_cv_5_p)\n",
    "    ad_rej_t = int(ad_t.statistic > ad_cv_5_t)\n",
    "\n",
    "    # ── Ljung–Box on Gaussianized PIT ───────────────────────────\n",
    "    lb_p = acorr_ljungbox(z_p, lags=lags_lb_c, return_df=True)\n",
    "    lb_t = acorr_ljungbox(z_t, lags=lags_lb_c, return_df=True)\n",
    "\n",
    "    # ── Energy Score (frozen ES scaling) ────────────────────────\n",
    "    es_val, _, _ = energy_score(\n",
    "        sims_p, sims_t, real_p, real_t,\n",
    "        MU_PRICE_ES, SD_PRICE_ES, MU_TEMP_ES, SD_TEMP_ES,\n",
